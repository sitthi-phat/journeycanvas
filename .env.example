# Copy this to .env in this journey_tool folder.

# Google Gemini API Key (optional — falls back to mock AI without it)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth (basic single-admin account) ---
ADMIN_USER=Admin
ADMIN_PASSWORD=12345
# Display name shown for the admin
ADMIN_LABEL=Admin
# Secret used to sign auth tokens. CHANGE THIS to a long random string in production.
AUTH_SECRET=change-me-to-a-long-random-string
# Admin login session length, in hours
ADMIN_SESSION_HOURS=24
# Invite-link lifetime AFTER first open (activation), in hours
INVITE_TTL_HOURS=12

# --- External machine API (/api/v1, Swagger docs at /api/docs) ---
# Static key other systems send as the X-API-Key header. Leave blank to disable the API.
API_KEY=change-me-to-a-secret-api-key
